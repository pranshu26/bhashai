{
  "name": "bhashai",
  "version": "0.1.0",
  "private": true,
  "description": "English to Indian-language document translation platform",
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "db:migrate": "pnpm --filter @bhashai/db prisma:migrate",
    "db:generate": "pnpm --filter @bhashai/db prisma:generate",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d postgres redis",
    "infra:down": "docker compose -f infra/docker-compose.yml down"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.5.0",
    "typescript": "^5.7.3"
  }
}
