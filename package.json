{
  "name": "bhashai",
  "version": "0.1.0",
  "private": true,
  "description": "English to Indian-language document translation platform",
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "db:generate": "pnpm --filter @bhashai/db exec prisma generate",
    "db:validate": "dotenv -e .env -- pnpm --filter @bhashai/db exec prisma validate",
    "db:migrate": "dotenv -e .env -- pnpm --filter @bhashai/db exec prisma migrate dev",
    "db:seed": "dotenv -e .env -- pnpm --filter @bhashai/db exec tsx prisma/seed.ts",
    "db:studio": "dotenv -e .env -- pnpm --filter @bhashai/db exec prisma studio",
    "infra:up": "docker compose --env-file .env -f infra/docker-compose.yml up -d postgres redis",
    "infra:down": "docker compose --env-file .env -f infra/docker-compose.yml down"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "dotenv-cli": "^8.0.0",
    "prettier": "^3.4.2",
    "turbo": "^2.5.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "prisma",
      "@prisma/client",
      "@prisma/engines",
      "argon2",
      "@nestjs/core"
    ]
  },
  "dependencies": {
    "modal": "^0.7.6"
  }
}
