# ─── Core infra ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://bhashai:bhashai@localhost:5432/bhashai
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-to-a-long-random-string
# If you already run Postgres/Redis locally on 5432/6379, override the container
# host ports here and match them in the URLs above (e.g. 5433 / 6380):
# POSTGRES_PORT=5433
# REDIS_PORT=6380

# ─── Storage ────────────────────────────────────────────────────────────────
# local = write to ./.data (no AWS needed for dev). s3 = use buckets below.
STORAGE_DRIVER=local
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_RAW=bhashai-raw-dev
S3_BUCKET_PROCESSED=bhashai-processed-dev

# ─── Translation engine ───────────────────────────────────────────────────────
# llm    = direct LLM translation via an OpenAI-compatible chat endpoint. Recommended:
#          OpenRouter Qwen-2.5-72B — complete, teacher-grade, consistent terminology.
# sarvam = Sarvam Translate API draft (fast/cheap, but partial on long paragraphs).
# indictrans = self-hosted IndicTrans2 NMT (needs INDICTRANS_SERVICE_URL).
TRANSLATE_ENGINE=llm
LLM_BASE_URL=                     # e.g. https://openrouter.ai/api/v1
LLM_API_KEY=                      # e.g. OpenRouter key (sk-or-v1-...)
LLM_MODEL=                        # e.g. qwen/qwen-2.5-72b-instruct (or meta-llama/llama-3.3-70b-instruct)
LLM_PROVIDER=                     # informational; blank + LLM_BASE_URL set => OpenAI-compatible
POST_EDIT_CONCURRENCY=8           # parallel translate requests
TRANSLATE_BATCH=6                 # paragraphs per request (count-mismatch -> per-item retry, never drops to English)
TRANSLATION_GLOSSARY=             # optional term pins, e.g. "AI=एआई; prompt=प्रॉम्प्ट"
# engine=sarvam (Indic-native draft):
SARVAM_API_KEY=                   # Sarvam Translate API key (sk_...) from dashboard.sarvam.ai
SARVAM_TRANSLATE_MODEL=mayura:v1
SARVAM_CONCURRENCY=8
OPENAI_API_KEY=                   # fallback only
ANTHROPIC_API_KEY=                # fallback only

# ─── Optional engines (full adapters, activate when infra/creds ready) ─────────
AWS_TRANSLATE_ENABLED=false
GOOGLE_TRANSLATE_ENABLED=false
GOOGLE_TRANSLATE_CREDENTIALS=
INDICTRANS_SERVICE_URL=           # e.g. http://localhost:8001 (services/indictrans)
INDICTRANS_MODEL=ai4bharat/indictrans2-en-indic-dist-200M  # 1B variant for GPU
HF_TOKEN=                         # HuggingFace read token (gated model download)

# ─── Services ──────────────────────────────────────────────────────────────
PARSER_SERVICE_URL=http://localhost:8000

# ─── Pipeline behavior ────────────────────────────────────────────────────────
DEFAULT_TRANSLATION_ENGINE=LLM    # MOCK for offline dev/CI
MAX_UPLOAD_MB=100
ENABLE_OCR=false                  # false | textract | local(tesseract)
ENABLE_LAYOUT_PRESERVATION=false
QA_PASS_THRESHOLD=70

# ─── Workers ──────────────────────────────────────────────────────────────
WORKER_QUEUES=*                   # * = all queues in one process, or CSV
WORKER_CONCURRENCY_TRANSLATION=4

# ─── Frontend ──────────────────────────────────────────────────────────────
# The web bakes this at BUILD time. For prod set http://<EC2-IP>/api and rebuild the web.
NEXT_PUBLIC_API_URL=http://localhost:3001/api
