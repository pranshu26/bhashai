# ─── Core infra ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://bhashai:bhashai@localhost:5432/bhashai
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-to-a-long-random-string
# If you already run Postgres/Redis locally on 5432/6379, override the container
# host ports here and match them in the URLs above (e.g. 5433 / 6380):
# POSTGRES_PORT=5433
# REDIS_PORT=6380

# ─── Storage ────────────────────────────────────────────────────────────────
# local = write to ./.data (no AWS needed for dev). s3 = use buckets below.
STORAGE_DRIVER=local
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_RAW=bhashai-raw-dev
S3_BUCKET_PROCESSED=bhashai-processed-dev

# ─── Translation engine ───────────────────────────────────────────────────────
# sarvam = Sarvam hosted Translation API (Indic-specialised, pay-per-token, no GPU). Recommended.
# indictrans = self-hosted IndicTrans2 NMT (needs INDICTRANS_SERVICE_URL); llm = chat-model translate.
TRANSLATE_ENGINE=sarvam
LLM_API_KEY=                      # Sarvam API key (sk_...) from dashboard.sarvam.ai — used by engine=sarvam
SARVAM_TRANSLATE_MODEL=mayura:v1  # mayura:v1 | sarvam-translate:v1
SARVAM_CONCURRENCY=8              # parallel translate requests
SARVAM_BATCH_LINES=15             # blocks packed (numbered) per request (SARVAM_BATCH_CHARS=700 caps size)

# Optional LLM post-edit / QA backend (used by engine=indictrans, or for QA). OpenAI-compatible.
LLM_BASE_URL=                     # e.g. https://api.sarvam.ai/v1 (chat) — blank disables post-edit
LLM_MODEL=                        # e.g. sarvam-30b; blank = provider default
LLM_PROVIDER=                     # blank + LLM_BASE_URL set => OpenAI-compatible; else anthropic|openai
POST_EDIT_CONCURRENCY=8
OPENAI_API_KEY=                   # fallback only
ANTHROPIC_API_KEY=                # fallback only

# ─── Optional engines (full adapters, activate when infra/creds ready) ─────────
AWS_TRANSLATE_ENABLED=false
GOOGLE_TRANSLATE_ENABLED=false
GOOGLE_TRANSLATE_CREDENTIALS=
INDICTRANS_SERVICE_URL=           # e.g. http://localhost:8001 (services/indictrans)
INDICTRANS_MODEL=ai4bharat/indictrans2-en-indic-dist-200M  # 1B variant for GPU
HF_TOKEN=                         # HuggingFace read token (gated model download)

# ─── Services ──────────────────────────────────────────────────────────────
PARSER_SERVICE_URL=http://localhost:8000

# ─── Pipeline behavior ────────────────────────────────────────────────────────
DEFAULT_TRANSLATION_ENGINE=LLM    # MOCK for offline dev/CI
MAX_UPLOAD_MB=100
ENABLE_OCR=false                  # false | textract | local(tesseract)
ENABLE_LAYOUT_PRESERVATION=false
QA_PASS_THRESHOLD=70

# ─── Workers ──────────────────────────────────────────────────────────────
WORKER_QUEUES=*                   # * = all queues in one process, or CSV
WORKER_CONCURRENCY_TRANSLATION=4

# ─── Frontend ──────────────────────────────────────────────────────────────
WEB_PUBLIC_API_URL=http://localhost:3001/api
