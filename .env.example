# ─── Core infra ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://bhashai:bhashai@localhost:5432/bhashai
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-to-a-long-random-string
# If you already run Postgres/Redis locally on 5432/6379, override the container
# host ports here and match them in the URLs above (e.g. 5433 / 6380):
# POSTGRES_PORT=5433
# REDIS_PORT=6380

# ─── Storage ────────────────────────────────────────────────────────────────
# local = write to ./.data (no AWS needed for dev). s3 = use buckets below.
STORAGE_DRIVER=local
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_RAW=bhashai-raw-dev
S3_BUCKET_PROCESSED=bhashai-processed-dev

# ─── Translation engine ───────────────────────────────────────────────────────
# Engine values:
#   indictrans+llm = two-pass: IndicTrans2 NMT draft + Indic-tuned LLM refine.
#                    ★ Production target — best Indian-language quality, fully open-source,
#                    rate-limit-free when run against the self-hosted backbone in
#                    infra/aws-gpu/. Errors if LLM_BASE_URL is not configured.
#   llm            = LLM-only (single pass). What's running today against OpenRouter Qwen.
#   sarvam         = Sarvam Translate API draft + optional LLM refine.
#   indictrans     = IndicTrans2 NMT only (with optional LLM refine when configured).
TRANSLATE_ENGINE=indictrans+llm

# Self-hosted backbone (infra/aws-gpu/ — one L40S serves both behind one endpoint):
LLM_BASE_URL=https://bhashai-backbone.example.com/v1
LLM_API_KEY=                              # bearer token printed by bootstrap.sh
LLM_MODEL=sarvam-m                        # Indian-tuned Mistral-Small3, 24B, Apache 2.0
INDICTRANS_SERVICE_URL=https://bhashai-backbone.example.com   # /translate_batch lives here
INDICTRANS_MODEL=ai4bharat/indictrans2-en-indic-1B            # 1B = GPU; 200M-dist = CPU/MPS dev

# Tuning:
POST_EDIT_CONCURRENCY=8           # parallel LLM refine requests
TRANSLATE_BATCH=6                 # paragraphs per LLM request (count-mismatch -> per-item retry)
TRANSLATION_GLOSSARY=             # raw "source=target; source=target" string; overrides services/parser/glossaries/<lang>.json

# Fallback engines (rarely used now — kept for emergencies):
SARVAM_API_KEY=                   # Sarvam Translate API key (sk_...) from dashboard.sarvam.ai
SARVAM_TRANSLATE_MODEL=mayura:v1
SARVAM_CONCURRENCY=8
LLM_PROVIDER=                     # blank + LLM_BASE_URL set => OpenAI-compatible
OPENAI_API_KEY=                   # not the prod path
ANTHROPIC_API_KEY=                # not the prod path
HF_TOKEN=                         # HuggingFace read token (only needed for local IndicTrans2 dev)

# ─── Optional engines (TS engine router; plaintext path only) ─────────────────
AWS_TRANSLATE_ENABLED=false
GOOGLE_TRANSLATE_ENABLED=false
GOOGLE_TRANSLATE_CREDENTIALS=

# ─── Services ──────────────────────────────────────────────────────────────
PARSER_SERVICE_URL=http://localhost:8000

# ─── Pipeline behavior ────────────────────────────────────────────────────────
DEFAULT_TRANSLATION_ENGINE=LLM    # MOCK for offline dev/CI
MAX_UPLOAD_MB=100
ENABLE_OCR=false                  # false | textract | local(tesseract)
ENABLE_LAYOUT_PRESERVATION=false
QA_PASS_THRESHOLD=70

# ─── Workers ──────────────────────────────────────────────────────────────
WORKER_QUEUES=*                   # * = all queues in one process, or CSV
WORKER_CONCURRENCY_TRANSLATION=4

# ─── Frontend ──────────────────────────────────────────────────────────────
# The web bakes this at BUILD time. For prod set http://<EC2-IP>/api and rebuild the web.
NEXT_PUBLIC_API_URL=http://localhost:3001/api
